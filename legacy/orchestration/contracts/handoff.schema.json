{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-orchestration/contracts/handoff.schema.json",
  "title": "Harness Handoff Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "task_id",
    "worker",
    "what_changed",
    "validation",
    "risks",
    "next_3_actions",
    "timestamp"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "task_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "worker": {
      "type": "string"
    },
    "what_changed": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "outcome"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "evidence_path": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "description"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "next_3_actions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}

