{
  "env": {
    "browser": true,
    "es6": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "no-undef": "error",
    "semi": ["warn", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "indent": ["warn", 2],
    "no-trailing-spaces": "warn",
    "eol-last": ["warn", "always"],
    "no-multiple-empty-lines": ["warn", { "max": 2, "maxEOF": 1 }]
  },
  "globals": {
    "Chart": "readonly",
    "lucide": "readonly",
    "Finance": "readonly",
    "Strategy": "readonly",
    "UI": "readonly",
    "Data": "readonly",
    "Charts": "readonly"
  }
}
