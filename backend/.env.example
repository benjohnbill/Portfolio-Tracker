# Local development template only.
# Do not place real secrets in this file.

# Required for backend startup and database access
DATABASE_URL=sqlite:///./backend/data/portfolio.db

# Required for protected cron endpoint calls
CRON_SECRET=replace-with-local-dev-secret

# Required only for KIS-backed integrations and scripts
KIS_APP_KEY=replace-with-kis-app-key
KIS_APP_SECRET=replace-with-kis-app-secret
KIS_URL_BASE=https://openapi.koreainvestment.com:9443
KIS_CANO=replace-with-kis-account-number
KIS_ACNT_PRDT_CD=replace-with-kis-product-code

# Optional / integration-specific
FINANCIAL_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY_MAIN=
WEEKLY_REPORT_LLM_PROVIDER=openai
WEEKLY_REPORT_OPENAI_MODEL=gpt-4o-mini
WEEKLY_REPORT_GEMINI_MODEL=gemini-2.5-flash
